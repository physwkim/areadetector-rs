#=================================================================#
# simDetector.db
# Database for SimDetector-specific parameters only.
# ADBase.db, NDArrayBase.db, and NDFile.db are loaded separately.
#=================================================================#

#----- Simulation Mode -----

record(longout, "$(P)$(R)SimMode") {
    field(DTYP, "asynSimDetector")
    field(VAL,  "0")
}

record(longin, "$(P)$(R)SimMode_RBV") {
    field(DTYP, "asynSimDetector")
    field(SCAN, "1 second")
}

