record(longout, "$(P)$(R)PeakStartX") {
    field(DTYP, "asynSimDetector")
    field(VAL,  "1")
}

record(longout, "$(P)$(R)PeakStartY") {
    field(DTYP, "asynSimDetector")
    field(VAL,  "1")
}

record(longout, "$(P)$(R)PeakWidthX") {
    field(DTYP, "asynSimDetector")
