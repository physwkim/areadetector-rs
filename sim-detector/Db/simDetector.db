}

record(stringin, "$(P)$(R)StatusMessage_RBV") {
    field(DTYP, "asynSimDetector")
    field(SCAN, "1 second")
}

record(longin, "$(P)$(R)MaxSizeX_RBV") {
    field(DTYP, "asynSimDetector")
    field(SCAN, "Passive")
    field(PINI, "YES")
}

record(longin, "$(P)$(R)MaxSizeY_RBV") {
    field(DTYP, "asynSimDetector")
    field(SCAN, "Passive")
    field(PINI, "YES")
}

record(longin, "$(P)$(R)ArraySizeX_RBV") {
