#=================================================================#
# simDetector.db
# Database for the Rust sim-detector IOC
# Modeled after ADSimDetector/simDetectorApp/Db/simDetector.template
#=================================================================#

#----- Acquisition Control -----

record(longout, "$(P)$(R)Acquire") {
    field(DTYP, "asynSimDetector")
    field(VAL,  "0")
}

record(longin, "$(P)$(R)Acquire_RBV") {
    field(DTYP, "asynSimDetector")
    field(SCAN, "1 second")
}

record(longout, "$(P)$(R)ImageMode") {
    field(DTYP, "asynSimDetector")
    field(VAL,  "2")
}

record(longin, "$(P)$(R)ImageMode_RBV") {
    field(DTYP, "asynSimDetector")
    field(SCAN, "1 second")
}

record(longout, "$(P)$(R)NumImages") {
    field(DTYP, "asynSimDetector")
    field(VAL,  "100")
}

record(longin, "$(P)$(R)NumImages_RBV") {
    field(DTYP, "asynSimDetector")
    field(SCAN, "1 second")
}

record(ao, "$(P)$(R)AcquireTime") {
    field(DTYP, "asynSimDetector")
    field(PREC, "4")
    field(VAL,  "0.001")
}

record(ai, "$(P)$(R)AcquireTime_RBV") {
    field(DTYP, "asynSimDetector")
    field(PREC, "4")
    field(SCAN, "1 second")
}

record(ao, "$(P)$(R)AcquirePeriod") {
    field(DTYP, "asynSimDetector")
    field(PREC, "4")
    field(VAL,  "0.005")
}

record(ai, "$(P)$(R)AcquirePeriod_RBV") {
    field(DTYP, "asynSimDetector")
    field(PREC, "4")
    field(SCAN, "1 second")
}

#----- Data Type & Color Mode -----

record(longout, "$(P)$(R)DataType") {
    field(DTYP, "asynSimDetector")
    field(VAL,  "1")
}

record(longin, "$(P)$(R)DataType_RBV") {
    field(DTYP, "asynSimDetector")
