#=================================================================#
# simDetector.db
# Converted from ADSimDetector/simDetectorApp/Db/simDetector.template for areadetector-rs
# Original: Mark Rivers, March 23, 2008
#
# Conversion rules:
#   - Removed INP/OUT asyn link fields (Rust IOC uses device support registration)
#   - Removed FLNK fields
#   - Removed info() directives
#   - DTYP set to "asynSimDetector"
#   - Kept all enum strings, SCAN, PINI, VAL, PREC, ZNAM/ONAM fields

# Redefine the color mode choices from ADBase to only have those that the simDetector
# driver supports.  Keep the same values (xxVL), but change the menu numbers.

record(mbbo, "$(P)$(R)ColorMode")
{
   field(DTYP, "asynSimDetector")
   field(ZRST, "Mono")
   field(ZRVL, "0")
   field(ONST, "RGB1")
   field(ONVL, "2")
   field(TWST, "RGB2")
   field(TWVL, "3")
   field(THST, "RGB3")
   field(THVL, "4")
   field(FRST, "")
   field(FVST, "")
   field(SXST, "")
   field(SVST, "")
   field(EIST, "")
}

record(mbbi, "$(P)$(R)ColorMode_RBV")
{
   field(DTYP, "asynSimDetector")
   field(ZRST, "Mono")
   field(ZRVL, "0")
   field(ONST, "RGB1")
   field(ONVL, "2")
   field(TWST, "RGB2")
   field(TWVL, "3")
   field(THST, "RGB3")
   field(THVL, "4")
   field(FRST, "")
   field(FVST, "")
   field(SXST, "")
   field(SVST, "")
   field(EIST, "")
   field(SCAN, "I/O Intr")
}

