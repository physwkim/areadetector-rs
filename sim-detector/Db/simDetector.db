#----- Status Readbacks -----

record(longin, "$(P)$(R)ArrayCounter_RBV") {
    field(DTYP, "asynSimDetector")
    field(SCAN, "1 second")
}

record(longin, "$(P)$(R)NumImagesCounter_RBV") {
    field(DTYP, "asynSimDetector")
