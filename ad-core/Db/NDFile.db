#=================================================================#
# NDFile.db
# Database for NDArrayDriver file I/O parameters
# Modeled after ADCore/ADApp/Db/NDFile.template
#
# Macros:
#   P     - PV name prefix
#   R     - PV name suffix
#=================================================================#

record(stringout, "$(P)$(R)FilePath") {
    field(DTYP, "asynSimDetector")
}

record(stringin, "$(P)$(R)FilePath_RBV") {
    field(DTYP, "asynSimDetector")
    field(SCAN, "1 second")
}

