#=================================================================#
# NDPluginBase.db
# Database for NDPlugin base parameters common to all plugins
# Modeled after ADCore/ADApp/Db/NDPluginBase.template
#
# Macros:
#   P            - PV name prefix
#   R            - PV name suffix
#   PORT         - asyn port name for this plugin
#   ADDR         - asyn address (default 0)
#   TIMEOUT      - asyn timeout (default 1)
#   NDARRAY_PORT - port name for NDArray source
#   DTYP         - device type for asyn communication
#=================================================================#

#----- Plugin Identity -----

record(stringin, "$(P)$(R)PortName_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "Passive")
    field(PINI, "1")
}

record(stringin, "$(P)$(R)PluginType_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "Passive")
    field(PINI, "1")
}

#----- NDArray Source Connection -----

record(stringout, "$(P)$(R)NDArrayPort") {
    field(DTYP, "$(DTYP)")
    field(VAL,  "$(NDARRAY_PORT)")
    field(PINI, "1")
}

record(stringin, "$(P)$(R)NDArrayPort_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "Passive")
    field(PINI, "1")
}

record(longout, "$(P)$(R)NDArrayAddress") {
    field(DTYP, "$(DTYP)")
    field(VAL,  "0")
    field(PINI, "1")
}

record(longin, "$(P)$(R)NDArrayAddress_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "Passive")
    field(PINI, "1")
}

#----- Callback Control -----

record(longout, "$(P)$(R)EnableCallbacks") {
    field(DTYP, "$(DTYP)")
    field(VAL,  "1")
    field(PINI, "1")
}

record(longin, "$(P)$(R)EnableCallbacks_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "I/O Intr")
    field(PINI, "1")
}

record(longout, "$(P)$(R)BlockingCallbacks") {
    field(DTYP, "$(DTYP)")
    field(VAL,  "0")
    field(PINI, "1")
}

record(longin, "$(P)$(R)BlockingCallbacks_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "I/O Intr")
    field(PINI, "1")
}

#----- Queue Status -----

record(longin, "$(P)$(R)QueueSize") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "Passive")
    field(PINI, "1")
}

record(longin, "$(P)$(R)QueueFree") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "1 second")
}

#----- Array Counters -----

record(longout, "$(P)$(R)DroppedArrays") {
    field(DTYP, "$(DTYP)")
    field(VAL,  "0")
}

record(longin, "$(P)$(R)DroppedArrays_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "1 second")
}

record(longin, "$(P)$(R)ArrayCounter_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "1 second")
}

record(calc, "$(P)$(R)ArrayRate_RBV") {
    field(INPA, "$(P)$(R)ArrayRate_RBV.B NPP NMS")
    field(INPB, "$(P)$(R)ArrayCounter_RBV NPP NMS")
    field(CALC, "B-A")
    field(SCAN, "1 second")
    field(PREC, "1")
    field(EGU,  "Hz")
}
