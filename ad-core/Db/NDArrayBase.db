#=================================================================#
# NDArrayBase.db
# Converted from ADCore/ADApp/Db/NDArrayBase.template for areadetector-rs
# Original: Mark Rivers, March 9, 2008
#
# Conversion rules:
#   - Removed INP/OUT asyn link fields (Rust IOC uses device support registration)
#   - Removed FLNK fields
#   - Removed info() directives
#   - DTYP set to "asynSimDetector"
#   - Removed subArray/fanout/calcout/busy/asyn records (EPICS database processing)
#   - Kept only records that map to asyn parameters

###################################################################
#  This record contains the version of ADCore                     #
###################################################################

record(stringin, "$(P)$(R)ADCoreVersion_RBV")
{
   field(DTYP, "asynSimDetector")
   field(VAL,  "Unknown")
   field(SCAN, "I/O Intr")
}

###################################################################
#  This record contains the version of the driver or plugin       #
###################################################################

record(stringin, "$(P)$(R)DriverVersion_RBV")
{
   field(DTYP, "asynSimDetector")
   field(VAL,  "Unknown")
   field(SCAN, "I/O Intr")
}

###################################################################
#  This record contains the asyn port name of this detector       #
###################################################################

record(stringin, "$(P)$(R)PortName_RBV")
{
   field(DTYP, "asynSimDetector")
   field(VAL,  "Unknown")
   field(SCAN, "I/O Intr")
}

###################################################################
#  These records contain basic information about the detector     #
###################################################################

record(stringin, "$(P)$(R)Manufacturer_RBV")
{
   field(DTYP, "asynSimDetector")
   field(VAL,  "Unknown")
   field(SCAN, "I/O Intr")
}

record(stringin, "$(P)$(R)Model_RBV")
{
   field(DTYP, "asynSimDetector")
   field(VAL,  "Unknown")
   field(SCAN, "I/O Intr")
}

record(stringin, "$(P)$(R)SerialNumber_RBV")
{
   field(DTYP, "asynSimDetector")
   field(VAL,  "Unknown")
   field(SCAN, "I/O Intr")
}

record(stringin, "$(P)$(R)SDKVersion_RBV")
{
   field(DTYP, "asynSimDetector")
   field(VAL,  "Unknown")
   field(SCAN, "I/O Intr")
}

record(stringin, "$(P)$(R)FirmwareVersion_RBV")
{
   field(DTYP, "asynSimDetector")
   field(VAL,  "Unknown")
   field(SCAN, "I/O Intr")
}

###################################################################
#  These records control acquisition start and stop               #
###################################################################

record(bo, "$(P)$(R)Acquire")
{
   field(DTYP, "asynSimDetector")
   field(ZNAM, "Done")
   field(ONAM, "Acquire")
   field(VAL,  "0")
}

record(bi, "$(P)$(R)Acquire_RBV")
{
   field(DTYP, "asynSimDetector")
   field(ZNAM, "Done")
   field(ZSV,  "NO_ALARM")
   field(ONAM, "Acquiring")
   field(OSV,  "MINOR")
   field(SCAN, "I/O Intr")
}

record(bo, "$(P)$(R)WaitForPlugins")
{
   field(PINI, "YES")
   field(DTYP, "asynSimDetector")
   field(ZNAM, "No")
   field(ONAM, "Yes")
   field(VAL,  "0")
}

###################################################################
#  These records are the array size and data type                 #
###################################################################

record(longout, "$(P)$(R)NDimensions")
{
    field(DTYP, "asynSimDetector")
}

record(longin, "$(P)$(R)NDimensions_RBV")
{
    field(DTYP, "asynSimDetector")
    field(SCAN, "I/O Intr")
}

record(mbbi, "$(P)$(R)BayerPattern_RBV")
{
   field(DTYP, "asynSimDetector")
   field(ZRST, "RGGB")
   field(ZRVL, "0")
   field(ONST, "GBRG")
   field(ONVL, "1")
   field(TWST, "GRBG")
   field(TWVL, "2")
   field(THST, "BGGR")
   field(THVL, "3")
   field(SCAN, "I/O Intr")
}

record(longin, "$(P)$(R)ArraySizeX_RBV")
{
   field(DTYP, "asynSimDetector")
   field(SCAN, "I/O Intr")
}

record(longin, "$(P)$(R)ArraySizeY_RBV")
{
   field(DTYP, "asynSimDetector")
   field(SCAN, "I/O Intr")
}

record(longin, "$(P)$(R)ArraySizeZ_RBV")
{
   field(DTYP, "asynSimDetector")
   field(SCAN, "I/O Intr")
}

record(longin, "$(P)$(R)ArraySize_RBV")
{
   field(DTYP, "asynSimDetector")
   field(SCAN, "I/O Intr")
}

###################################################################
#  These records have information on the compression              #
###################################################################

record(stringin, "$(P)$(R)Codec_RBV")
{
   field(DTYP, "asynSimDetector")
   field(VAL,  "")
   field(SCAN, "I/O Intr")
}

record(longin, "$(P)$(R)CompressedSize_RBV")
{
   field(DTYP, "asynSimDetector")
   field(SCAN, "I/O Intr")
}

###################################################################
#  These records control the data type                            #
###################################################################

record(mbbo, "$(P)$(R)DataType")
{
   field(PINI, "YES")
   field(DTYP, "asynSimDetector")
   field(ZRST, "Int8")
   field(ZRVL, "0")
   field(ONST, "UInt8")
   field(ONVL, "1")
   field(TWST, "Int16")
   field(TWVL, "2")
   field(THST, "UInt16")
   field(THVL, "3")
   field(FRST, "Int32")
   field(FRVL, "4")
   field(FVST, "UInt32")
   field(FVVL, "5")
   field(SXST, "Int64")
   field(SXVL, "6")
   field(SVST, "UInt64")
   field(SVVL, "7")
   field(EIST, "Float32")
   field(EIVL, "8")
   field(NIST, "Float64")
   field(NIVL, "9")
   field(VAL,  "0")
}

record(mbbi, "$(P)$(R)DataType_RBV")
{
   field(DTYP, "asynSimDetector")
   field(ZRST, "Int8")
   field(ZRVL, "0")
   field(ONST, "UInt8")
   field(ONVL, "1")
   field(TWST, "Int16")
   field(TWVL, "2")
   field(THST, "UInt16")
   field(THVL, "3")
   field(FRST, "Int32")
   field(FRVL, "4")
   field(FVST, "UInt32")
   field(FVVL, "5")
   field(SXST, "Int64")
   field(SXVL, "6")
   field(SVST, "UInt64")
   field(SVVL, "7")
   field(EIST, "Float32")
   field(EIVL, "8")
   field(NIST, "Float64")
   field(NIVL, "9")
   field(SCAN, "I/O Intr")
}

###################################################################
#  These records control the color mode                           #
#  These choices must agree with NDColorMode_t in NDArray.h       #
###################################################################

record(mbbo, "$(P)$(R)ColorMode")
{
   field(PINI, "YES")
   field(DTYP, "asynSimDetector")
   field(ZRST, "Mono")
   field(ZRVL, "0")
   field(ONST, "Bayer")
   field(ONVL, "1")
   field(TWST, "RGB1")
   field(TWVL, "2")
   field(THST, "RGB2")
   field(THVL, "3")
   field(FRST, "RGB3")
   field(FRVL, "4")
   field(FVST, "YUV444")
   field(FVVL, "5")
   field(SXST, "YUV422")
   field(SXVL, "6")
   field(SVST, "YUV421")
   field(SVVL, "7")
}

record(mbbi, "$(P)$(R)ColorMode_RBV")
{
   field(DTYP, "asynSimDetector")
   field(ZRST, "Mono")
   field(ZRVL, "0")
   field(ONST, "Bayer")
   field(ONVL, "1")
   field(TWST, "RGB1")
   field(TWVL, "2")
   field(THST, "RGB2")
   field(THVL, "3")
   field(FRST, "RGB3")
   field(FRVL, "4")
   field(FVST, "YUV444")
   field(FVVL, "5")
   field(SXST, "YUV422")
   field(SXVL, "6")
   field(SVST, "YUV421")
   field(SVVL, "7")
   field(SCAN, "I/O Intr")
}

###################################################################
#  These records are the uniqueId and time stamps of the array    #
###################################################################

record(longin, "$(P)$(R)UniqueId_RBV")
{
    field(DTYP, "asynSimDetector")
    field(SCAN, "I/O Intr")
}

record(ai, "$(P)$(R)TimeStamp_RBV")
{
    field(DTYP, "asynSimDetector")
    field(PREC, "3")
    field(SCAN, "I/O Intr")
}

record(longin, "$(P)$(R)EpicsTSSec_RBV")
{
    field(DTYP, "asynSimDetector")
    field(SCAN, "I/O Intr")
}

record(longin, "$(P)$(R)EpicsTSNsec_RBV")
{
    field(DTYP, "asynSimDetector")
    field(SCAN, "I/O Intr")
}

###################################################################
#  These records provide statistics on array callbacks and        #
#  array callback rates                                           #
###################################################################

record(longout, "$(P)$(R)ArrayCounter")
{
    field(DTYP, "asynSimDetector")
}

record(longin, "$(P)$(R)ArrayCounter_RBV")
{
    field(DTYP, "asynSimDetector")
    field(SCAN, "I/O Intr")
}

record(calc, "$(P)$(R)ArrayRate_RBV")
{
    field(INPA, "$(P)$(R)ArrayRate_RBV.LB NPP NMS")
    field(INPB, "$(P)$(R)ArrayCounter_RBV NPP NMS")
    field(INPC, "1.0")
    field(INPD, "$(P)$(R)ArrayRate_RBV.VAL NPP NMS")
    field(INPE, "0.0")
    field(CALC, "(D*E)/C+MAX(0,B-A)*(1-E)/C")
    field(PREC, "2")
    field(EGU,  "Hz")
    field(SCAN, "1 second")
}

###################################################################
#  These records control NDArray callbacks                        #
###################################################################

record(bo, "$(P)$(R)ArrayCallbacks")
{
    field(PINI, "YES")
    field(DTYP, "asynSimDetector")
    field(ZNAM, "Disable")
    field(ZSV,  "NO_ALARM")
    field(ONAM, "Enable")
    field(OSV,  "MINOR")
    field(VAL,  "1")
}

record(bi, "$(P)$(R)ArrayCallbacks_RBV")
{
    field(DTYP, "asynSimDetector")
    field(ZNAM, "Disable")
    field(ZSV,  "NO_ALARM")
    field(ONAM, "Enable")
    field(OSV,  "MINOR")
    field(SCAN, "I/O Intr")
}

###################################################################
#  This record defines the status of reading attributes file      #
###################################################################

record(mbbi, "$(P)$(R)NDAttributesStatus")
{
    field(DTYP, "asynSimDetector")
    field(ZRVL, "0")
    field(ZRST, "Attributes file OK")
    field(ZRSV, "NO_ALARM")
    field(ONVL, "1")
    field(ONST, "File not found")
    field(ONSV, "MINOR")
    field(TWVL, "2")
    field(TWST, "XML syntax error")
    field(TWSV, "MAJOR")
    field(THVL, "3")
    field(THST, "Macro substitution error")
    field(THSV, "MAJOR")
    field(SCAN, "I/O Intr")
}

###################################################################
#  Status of NDArrayPool - number of buffers, memory used etc.    #
###################################################################

record(ai, "$(P)$(R)PoolMaxMem")
{
   field(DTYP, "asynSimDetector")
   field(PREC, "1")
   field(EGU,  "MB")
   field(SCAN, "Passive")
   field(PINI, "YES")
}

record(ai, "$(P)$(R)PoolUsedMem")
{
   field(DTYP, "asynSimDetector")
   field(PREC, "1")
   field(EGU,  "MB")
   field(SCAN, "I/O Intr")
}

record(longin, "$(P)$(R)PoolAllocBuffers")
{
   field(DTYP, "asynSimDetector")
   field(SCAN, "I/O Intr")
}

record(longin, "$(P)$(R)PoolFreeBuffers")
{
   field(DTYP, "asynSimDetector")
   field(SCAN, "I/O Intr")
}

record(calc, "$(P)$(R)PoolUsedBuffers")
{
    field(INPA, "$(P)$(R)PoolAllocBuffers CP MS")
    field(INPB, "$(P)$(R)PoolFreeBuffers CP MS")
    field(CALC, "A-B")
}

record(longin, "$(P)$(R)NumQueuedArrays")
{
   field(DTYP, "asynSimDetector")
   field(SCAN, "I/O Intr")
}
