#=================================================================#
# NDStdArrays.db
# Converted from ADCore/ADApp/Db/NDStdArrays.template for areadetector-rs
# Original: Mark Rivers, April 14, 2008
#
# Conversion rules:
#   - Removed INP/OUT asyn link fields (Rust IOC uses device support registration)
#   - DTYP set to "$(DTYP)" for per-plugin substitution
#   - SCAN changed to "1 second" (IOC doesn't support I/O Intr for array data yet)
#   - Kept FTVL and NELM from original

###################################################################
#  This record is the array waveform data                         #
###################################################################

record(waveform, "$(P)$(R)ArrayData")
{
    field(DTYP, "$(DTYP)")
    field(FTVL, "$(FTVL)")
    field(NELM, "$(NELEMENTS)")
    field(SCAN, "1 second")
}
