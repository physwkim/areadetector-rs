#=================================================================#
# NDStats.db
# Database for NDStats plugin parameters
# Modeled after ADCore/ADApp/Db/NDStats.template
#
# Macros:
#   P     - PV name prefix
#   R     - PV name suffix
#   PORT  - asyn port name for this plugin
#   ADDR  - asyn address (default 0)
#   TIMEOUT - asyn timeout (default 1)
#   DTYP  - device type for asyn communication
#=================================================================#

#----- Compute Enable -----

record(longout, "$(P)$(R)ComputeStatistics") {
    field(DTYP, "$(DTYP)")
    field(VAL,  "0")
    field(PINI, "1")
}

record(longin, "$(P)$(R)ComputeStatistics_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "1 second")
    field(PINI, "1")
}

record(longout, "$(P)$(R)ComputeCentroid") {
    field(DTYP, "$(DTYP)")
    field(VAL,  "0")
    field(PINI, "1")
}

record(longin, "$(P)$(R)ComputeCentroid_RBV") {
    field(DTYP, "$(DTYP)")
    field(SCAN, "1 second")
    field(PINI, "1")
}

#----- Basic Statistics -----

record(ai, "$(P)$(R)MinValue_RBV") {
    field(DTYP, "$(DTYP)")
    field(PREC, "1")
    field(SCAN, "1 second")
    field(PINI, "1")
}

record(ai, "$(P)$(R)MaxValue_RBV") {
    field(DTYP, "$(DTYP)")
    field(PREC, "1")
    field(SCAN, "1 second")
    field(PINI, "1")
}

record(ai, "$(P)$(R)MeanValue_RBV") {
    field(DTYP, "$(DTYP)")
    field(PREC, "3")
    field(SCAN, "1 second")
    field(PINI, "1")
}

record(ai, "$(P)$(R)SigmaValue_RBV") {
    field(DTYP, "$(DTYP)")
    field(PREC, "3")
    field(SCAN, "1 second")
    field(PINI, "1")
}

record(ai, "$(P)$(R)Total_RBV") {
    field(DTYP, "$(DTYP)")
    field(PREC, "1")
    field(SCAN, "1 second")
    field(PINI, "1")
}

record(ai, "$(P)$(R)Net_RBV") {
    field(DTYP, "$(DTYP)")
    field(PREC, "1")
    field(SCAN, "1 second")
    field(PINI, "1")
}

#----- Centroid Statistics -----

record(ai, "$(P)$(R)CentroidX_RBV") {
    field(DTYP, "$(DTYP)")
    field(PREC, "3")
    field(SCAN, "1 second")
    field(PINI, "1")
}

record(ai, "$(P)$(R)CentroidY_RBV") {
    field(DTYP, "$(DTYP)")
    field(PREC, "3")
    field(SCAN, "1 second")
    field(PINI, "1")
}

record(ai, "$(P)$(R)SigmaX_RBV") {
    field(DTYP, "$(DTYP)")
    field(PREC, "3")
    field(SCAN, "1 second")
    field(PINI, "1")
}

record(ai, "$(P)$(R)SigmaY_RBV") {
    field(DTYP, "$(DTYP)")
    field(PREC, "3")
    field(SCAN, "1 second")
    field(PINI, "1")
}
