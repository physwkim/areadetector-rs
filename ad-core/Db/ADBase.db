#=================================================================#
# ADBase.db
# Database for ADDriver base parameters
# Modeled after ADCore/ADApp/Db/ADBase.template
#
# Macros:
#   P     - PV name prefix
#   R     - PV name suffix
#=================================================================#

#----- Image Size -----

record(longin, "$(P)$(R)MaxSizeX_RBV") {
    field(DTYP, "asynSimDetector")
    field(SCAN, "Passive")
    field(PINI, "YES")
}

record(longin, "$(P)$(R)MaxSizeY_RBV") {
    field(DTYP, "asynSimDetector")
    field(SCAN, "Passive")
    field(PINI, "YES")
}

record(longout, "$(P)$(R)SizeX") {
    field(DTYP, "asynSimDetector")
    field(VAL,  "256")
}

record(longin, "$(P)$(R)SizeX_RBV") {
    field(DTYP, "asynSimDetector")
    field(SCAN, "1 second")
}

