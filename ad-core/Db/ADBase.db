#=================================================================#
# ADBase.db
# Converted from ADCore/ADApp/Db/ADBase.template for areadetector-rs
# Original: Mark Rivers, March 9, 2008
#
# Conversion rules:
#   - Removed INP/OUT asyn link fields (Rust IOC uses device support registration)
#   - Removed FLNK fields
#   - Removed info() directives
#   - DTYP set to "asynSimDetector"
#   - Kept all enum strings, SCAN, PINI, VAL, PREC, EGU, ZNAM/ONAM fields

record(longin, "$(P)$(R)MaxSizeX_RBV")
{
   field(DTYP, "asynSimDetector")
   field(SCAN, "I/O Intr")
}

record(longin, "$(P)$(R)MaxSizeY_RBV")
{
   field(DTYP, "asynSimDetector")
   field(SCAN, "I/O Intr")
}

